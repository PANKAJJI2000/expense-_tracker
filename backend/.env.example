# ===========================================
# Expense Tracker Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control!

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
NODE_ENV=development
API_VERSION=v1

# ===========================================
# MongoDB Database Configuration
# ===========================================
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/expense_tracker

# MongoDB Atlas (Cloud) - Comment out local and use this for production
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/expense_tracker?retryWrites=true&w=majority

# ===========================================
# JWT Authentication
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Admin JWT (separate secret for admin panel)
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-change-this

# ===========================================
# Session Configuration
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-change-in-production

# ===========================================
# Email Service Configuration (Nodemailer)
# ===========================================
# For Gmail: Enable "Less secure app access" or use App Password
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ===========================================
# Frontend URLs
# ===========================================
# Used for email verification links, password reset, etc.
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ===========================================
# Google OAuth Configuration (Optional)
# ===========================================
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# LinkedIn OAuth Configuration (Optional)
# ===========================================
# Get credentials from: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ===========================================
# File Upload Configuration
# ===========================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ===========================================
# Production Settings (Render/Vercel/etc.)
# ===========================================
# Uncomment these for production deployment
# NODE_ENV=production
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://admin.your-app.vercel.app
